<view class="page">
  <view class="hero">
    <view class="eyebrow">Materials</view>
    <text class="title">材料库存与价格</text>
  </view>

  <view class="card">
    <view class="card-title">
      <text>材料导入</text>
      <text class="muted">价格频繁更新</text>
    </view>
    <view class="btn-row">
      <button class="primary" bindtap="chooseMaterialFile">导入材料表</button>
      <button bindtap="addMaterial">新增材料</button>
    </view>
    <view class="muted">{{importStatus}}</view>
  </view>

  <view class="card">
    <view class="card-title">
      <text>材料清单</text>
      <text class="muted">{{materials.length}} 种</text>
    </view>
    <block wx:for="{{materials}}" wx:key="name">
      <view class="row">
        <view>
          <view class="strong">{{item.name}}</view>
          <view class="muted">{{item.type}} / {{item.spec}}</view>
          <view class="muted">库存 {{item.qty}}{{item.unit}} / 损耗 {{item.loss}}%</view>
        </view>
        <view>
          <view class="money">¥{{item.price}}</view>
          <view class="muted">/{{item.unit}}</view>
        </view>
      </view>
    </block>
  </view>
</view>
