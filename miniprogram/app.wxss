page {
  background: #f6f8f3;
  color: #1d2923;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 140rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #69756d;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.card {
  background: #ffffff;
  border: 1rpx solid #dce2d9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.card-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  font-weight: 800;
  font-size: 32rpx;
}

.muted {
  color: #69756d;
  font-size: 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.metric {
  background: #eef4ed;
  border-radius: 14rpx;
  padding: 18rpx;
}

.metric-label {
  display: block;
  color: #69756d;
  font-size: 23rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #e5ebe2;
}

.row:first-child {
  border-top: 0;
  padding-top: 0;
}

.strong {
  font-weight: 800;
}

.money {
  color: #176f52;
  font-weight: 800;
}

.danger {
  color: #b42318;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin: 18rpx 0;
}

button {
  height: 76rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d8dfd5;
  background: #ffffff;
  color: #1d2923;
  font-weight: 700;
  font-size: 28rpx;
  line-height: 76rpx;
}

button.primary {
  background: #176f52;
  border-color: #176f52;
  color: #ffffff;
}

.field {
  display: block;
  margin-bottom: 18rpx;
}

.label {
  display: block;
  color: #69756d;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

input,
picker {
  min-height: 76rpx;
  border: 1rpx solid #d8dfd5;
  border-radius: 12rpx;
  background: #ffffff;
  padding: 0 18rpx;
  box-sizing: border-box;
  line-height: 76rpx;
}

.line-card {
  border: 1rpx solid #dce2d9;
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
}

.line-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.mini-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.empty {
  text-align: center;
  color: #69756d;
  padding: 48rpx 0;
}

.photo-box {
  border: 2rpx dashed #bcc8bd;
  border-radius: 16rpx;
  background: #fbfcfa;
  padding: 26rpx;
  text-align: center;
}

.preview-img {
  width: 100%;
  border-radius: 12rpx;
  margin-top: 18rpx;
}
